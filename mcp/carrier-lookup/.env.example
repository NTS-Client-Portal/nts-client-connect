# NTS Carrier MCP server
#
# FMCSA QCMobile API key. Register (free) at:
#   https://mobile.fmcsa.dot.gov/QCDevsite/docs/getStarted
# Without this, the lookup_carrier_by_mc tool returns an actionable error but
# attach_carrier_to_order / set_carrier_visibility still work with manual data.
FMCSA_WEBKEY=

# Supabase — reuse the same project the portal uses.
# The SERVICE ROLE key is required to write carrier_* columns and flip the
# carrier_visible_to_shipper flag (bypasses RLS). Keep this secret; this server
# is meant to run broker-side / server-side only, never in the browser.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
